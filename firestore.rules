rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isAdminClaim() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isAdminProfile() {
      return signedIn()
        && exists(profilePath(uid()))
        && profile(uid()).role == 'admin'
        && profile(uid()).status == 'active';
    }

    function isAdmin() {
      return isAdminClaim() || isAdminProfile();
    }

    function profilePath(userId) {
      return /databases/$(database)/documents/profiles/$(userId);
    }

    function profile(userId) {
      return get(profilePath(userId)).data;
    }

    function isTrialActive(userId) {
      return profile(userId).status == 'trialing'
        && profile(userId).trial_ends_at is timestamp
        && profile(userId).trial_ends_at > request.time;
    }

    function validNewTrialEnd() {
      return request.resource.data.trial_ends_at is timestamp
        && request.resource.data.trial_ends_at > request.time
        && request.resource.data.trial_ends_at.toMillis() <= request.time.toMillis() + 1296000000;
    }

    function isTenantActive(userId) {
      return signedIn()
        && exists(profilePath(userId))
        && profile(userId).role == 'tenant'
        && (profile(userId).status == 'active' || isTrialActive(userId));
    }

    function ownsExistingData() {
      return signedIn() && resource.data.user_id == uid();
    }

    function ownsIncomingData() {
      return signedIn() && request.resource.data.user_id == uid();
    }

    function keepsOwner() {
      return !('user_id' in resource.data)
        || request.resource.data.user_id == resource.data.user_id;
    }

    function validProfileStatus(status) {
      return status in ['trialing', 'active', 'blocked', 'cancelled'];
    }

    function validOrcamentoStatus(status) {
      return status in [
        'rascunho',
        'enviado',
        'visualizado',
        'aprovado',
        'recusado',
        'concluído',
        'pendente',
        'concluido',
        'rejeitado'
      ];
    }

    function validPublicOrcamentoData(publicId) {
      return request.resource.data.user_id == uid()
        && request.resource.data.share_token == publicId
        && validOrcamentoStatus(request.resource.data.status);
    }

    function isPublicViewTransition() {
      return resource.data.status == 'enviado'
        && request.resource.data.status == 'visualizado'
        && request.resource.data.viewed_at is string;
    }

    function isPublicDecisionTransition() {
      return resource.data.status in ['enviado', 'visualizado']
        && request.resource.data.status in ['aprovado', 'recusado']
        && request.resource.data.responded_at is string;
    }

    function validPublicStatusUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'viewed_at',
          'responded_at',
          'updated_at'
        ])
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.orcamento_id == resource.data.orcamento_id
        && request.resource.data.share_token == resource.data.share_token
        && request.resource.data.updated_at is string
        && (isPublicViewTransition() || isPublicDecisionTransition());
    }

    function validCounterData(userId) {
      return request.resource.data.user_id == userId
        && request.resource.data.next_orcamento_number is int
        && request.resource.data.next_orcamento_number >= 1;
    }

    function orcamentoPath(orcamentoId) {
      return /databases/$(database)/documents/orcamentos/$(orcamentoId);
    }

    function ownsOrcamento(orcamentoId) {
      return signedIn()
        && exists(orcamentoPath(orcamentoId))
        && get(orcamentoPath(orcamentoId)).data.user_id == uid();
    }

    match /profiles/{userId} {
      allow get: if signedIn() && (userId == uid() || isAdmin());
      allow list: if isAdmin();

      allow create: if signedIn()
        && userId == uid()
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'tenant'
        && request.resource.data.status == 'trialing'
        && request.resource.data.plan == 'trial'
        && validNewTrialEnd();

      allow update: if signedIn()
        && userId == uid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'display_name',
          'phone',
          'business_type',
          'updated_at'
        ])
        || (
          isAdmin()
          && validProfileStatus(request.resource.data.status)
        );

      allow delete: if isAdmin();
    }

    match /company_profiles/{userId} {
      allow read: if signedIn() && (userId == uid() || isAdmin());
      allow create: if userId == uid()
        && isTenantActive(uid())
        && ownsIncomingData();
      allow update: if signedIn()
        && userId == uid()
        && isTenantActive(uid())
        && keepsOwner()
        && request.resource.data.user_id == uid();
      allow delete: if isAdmin();
    }

    match /catalog_overrides/{userId} {
      allow read: if signedIn() && (userId == uid() || isAdmin());
      allow create: if signedIn()
        && userId == uid()
        && isTenantActive(uid())
        && request.resource.data.user_id == uid();
      allow update: if signedIn()
        && userId == uid()
        && isTenantActive(uid())
        && keepsOwner()
        && request.resource.data.user_id == uid();
      allow delete: if signedIn() && userId == uid() && isTenantActive(uid());
    }

    match /tenant_counters/{userId} {
      allow read: if signedIn() && (userId == uid() || isAdmin());
      allow create, update: if signedIn()
        && userId == uid()
        && isTenantActive(uid())
        && validCounterData(userId);
      allow delete: if false;
    }

    match /clientes/{clienteId} {
      allow read: if isAdmin() || (ownsExistingData() && isTenantActive(uid()));
      allow create: if ownsIncomingData() && isTenantActive(uid());
      allow update: if ownsExistingData()
        && isTenantActive(uid())
        && keepsOwner()
        && request.resource.data.user_id == uid();
      allow delete: if ownsExistingData() && isTenantActive(uid());
    }

    match /orcamentos/{orcamentoId} {
      allow read: if isAdmin() || (ownsExistingData() && isTenantActive(uid()));
      allow create: if ownsIncomingData()
        && isTenantActive(uid())
        && validOrcamentoStatus(request.resource.data.status);
      allow update: if ownsExistingData()
        && isTenantActive(uid())
        && keepsOwner()
        && request.resource.data.user_id == uid()
        && validOrcamentoStatus(request.resource.data.status);
      allow delete: if ownsExistingData() && isTenantActive(uid());

      match /revisions/{revisionId} {
        allow read: if isAdmin() || (ownsOrcamento(orcamentoId) && isTenantActive(uid()));
        allow create: if signedIn()
          && isTenantActive(uid())
          && ownsOrcamento(orcamentoId)
          && request.resource.data.user_id == uid()
          && request.resource.data.orcamento_id == orcamentoId;
        allow update, delete: if false;
      }
    }

    match /public_orcamentos/{publicId} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn()
        && isTenantActive(uid())
        && validPublicOrcamentoData(publicId);
      allow update: if (
          signedIn()
          && resource.data.user_id == uid()
          && isTenantActive(uid())
          && validPublicOrcamentoData(publicId)
        ) || validPublicStatusUpdate();
      allow delete: if signedIn()
        && resource.data.user_id == uid()
        && isTenantActive(uid());
    }

    match /usage/{userId} {
      allow read: if signedIn() && (userId == uid() || isAdmin());
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
